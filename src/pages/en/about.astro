---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { person } from "../../content/site";
---

<BaseLayout title={`About — ${person.name}`} lang="en" description="About Jiayi (Maxine) Gu.">
  <section class="container hero">
    <div class="reveal">
      <h1>About</h1>
      <p>
        I’m {person.name}, a UI/UX designer. I turn complex problems into clear interaction systems, then shape them into
        calm, readable interfaces—built for real workflows and edge cases.
      </p>
    </div>
  </section>

  <section class="container">
    <div class="grid">
      <div class="work-card reveal" style="grid-column: span 12; padding: 18px;">
        <h3 style="margin:0; font-size:14px; letter-spacing:0.12em; text-transform:uppercase; color: rgba(20,20,20,0.7);">
          Focus
        </h3>
        <p style="margin: 12px 0 0; color: rgba(20,20,20,0.62); line-height:1.75;">
          Complex B2B workflows · Information architecture · Interaction models · Design systems · Data visualization · Accessibility
        </p>
      </div>

      <div class="work-card reveal" style="grid-column: span 12; padding: 18px;">
        <h3 style="margin:0; font-size:14px; letter-spacing:0.12em; text-transform:uppercase; color: rgba(20,20,20,0.7);">
          Skills
        </h3>
        <div class="tags" style="margin-top: 12px;">
          {[
            "Product Thinking",
            "Information Architecture",
            "Interaction Design",
            "Prototyping",
            "Design Systems",
            "Responsive UI",
            "Accessibility",
            "Figma",
          ].map((t) => (
            <span class="tag">{t}</span>
          ))}
        </div>
      </div>

      <div class="work-card reveal" style="grid-column: span 12; padding: 18px;">
        <h3 style="margin:0; font-size:14px; letter-spacing:0.12em; text-transform:uppercase; color: rgba(20,20,20,0.7);">
          Contact
        </h3>
        <p style="margin: 12px 0 0; color: rgba(20,20,20,0.62); line-height:1.75;">
          Email: <a href="mailto:gujiayi2@gmail.com" style="border-bottom: 1px solid rgba(20,20,20,0.14);">gujiayi2@gmail.com</a>
        </p>
      </div>
    </div>
  </section>
</BaseLayout>

