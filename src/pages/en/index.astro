---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Decorations from "../../components/Decorations.astro";
import { person, projects, ui } from "../../content/site";
---

<BaseLayout
  title={`${person.name} — ${person.title}`}
  description="UI/UX design portfolio. Selected work, case studies, and contact."
  lang="en"
>
  <section class="container hero">
    <div class="reveal">
      <h1>{ui.home.hero.en}</h1>
      <p>{ui.home.sub.en}</p>
      <p style="margin-top: 10px">
        <a
          href="mailto:gujiayi2@gmail.com"
          style="color: rgba(20,20,20,0.72); border-bottom: 1px solid rgba(20,20,20,0.14)"
          >{person.email}</a
        >
      </p>
    </div>
  </section>

  <section class="container" style="position: relative">
    <Decorations variant="work" />
    <div class="section-head reveal">
      <h2>{ui.home.section.en}</h2>
      <p class="meta">{ui.home.meta.en}</p>
    </div>

    <div class="grid">
      {projects.map((p, idx) => {
        const href = p.externalUrl ? p.externalUrl : `/en/work/${p.slug}`;
        const isExternal = Boolean(p.externalUrl);
        const feature = idx === 0 || idx === 1;
        return (
          <a
            class={`work-card reveal ${feature ? "feature" : ""}`}
            href={href}
            target={isExternal ? "_blank" : undefined}
            rel={isExternal ? "noreferrer" : undefined}
            style={`view-transition-name: card-${p.slug};`}
          >
            <div class="cover" style={`view-transition-name: cover-${p.slug};`}>
              <img src={p.cover.src} alt={p.cover.alt} loading="lazy" decoding="async" />
            </div>
            <div class="work-body">
              <div class="work-title">
                <h3 style={`view-transition-name: title-${p.slug};`}>{p.title.en}</h3>
                <span style="color: rgba(20,20,20,0.36); font-size: 12px">
                  {isExternal ? "↗" : "→"}
                </span>
              </div>
              <div class="tags">
                {p.tags.slice(0, 3).map((t) => (
                  <span class={`tag ${t === "B2B SaaS" || t === "AIGC" ? "accent" : ""}`}>{t}</span>
                ))}
              </div>
            </div>
          </a>
        );
      })}
    </div>

    <footer class="footer">
      <div>© {new Date().getFullYear()} {person.name}</div>
      <div style="display:flex; gap: 12px; flex-wrap: wrap; justify-content:flex-end;">
        <a href="/">中文</a>
        <a href="/en/about">About</a>
        <a href="mailto:gujiayi2@gmail.com">Email</a>
      </div>
    </footer>
  </section>
</BaseLayout>

