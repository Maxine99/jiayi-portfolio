---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { projects, person } from "../../../content/site";

export function getStaticPaths() {
  return projects
    .filter((p) => !p.externalUrl)
    .map((p) => ({
      params: { slug: p.slug },
    }));
}

const { slug } = Astro.params;
const project = projects.find((p) => p.slug === slug);
if (!project || project.externalUrl) {
  return Astro.redirect("/en/");
}
---

<BaseLayout title={`${project.title.en} — ${person.name}`} lang="en" description={project.summary.en}>
  <section class="container hero">
    <div class="reveal">
      <h1 style={`view-transition-name: title-${project.slug};`}>{project.title.en}</h1>
      <p>{project.summary.en}</p>
      <div class="tags" style="margin-top: 14px;">
        {project.tags.map((t) => (
          <span class={`tag ${t === "B2B SaaS" || t === "AIGC" ? "accent" : ""}`}>{t}</span>
        ))}
      </div>
    </div>
  </section>

  <section class="container">
    <div
      class="work-card reveal"
      style="overflow:hidden; padding:0; border-radius: calc(var(--radius) + 6px);"
    >
      <div class="cover" style={`view-transition-name: cover-${project.slug}; aspect-ratio: 16/9;`}>
        <img src={project.cover.src} alt={project.cover.alt} decoding="async" />
      </div>
    </div>

    <div class="grid" style="margin-top: 18px;">
      <div class="work-card reveal" style="grid-column: span 12; padding: 18px;">
        <h3 style="margin:0; font-size:14px; letter-spacing:0.12em; text-transform:uppercase; color: rgba(20,20,20,0.7);">
          Case Study
        </h3>
        <p style="margin: 12px 0 0; color: rgba(20,20,20,0.62); line-height:1.75; max-width: 70ch;">
          You’ll replace these blocks with your Figma frames and write-up. The structure is ready for a full case study.
        </p>
      </div>

      {[
        "Project Overview",
        "My Role",
        "Context",
        "Goals",
        "Process",
        "Key Screens",
        "Outcome / Learnings",
      ].map((title) => (
        <div class="work-card reveal" style="grid-column: span 12; padding: 18px;">
          <h3 style="margin:0; font-size:14px; letter-spacing:0.12em; text-transform:uppercase; color: rgba(20,20,20,0.7);">
            {title}
          </h3>
          <p style="margin: 12px 0 0; color: rgba(20,20,20,0.62); line-height:1.75;">
            Placeholder — replace with your content.
          </p>
        </div>
      ))}
    </div>

    <footer class="footer">
      <div>© {new Date().getFullYear()} {person.name}</div>
      <div style="display:flex; gap: 12px; flex-wrap: wrap; justify-content:flex-end;">
        <a href="/en/">Work</a>
        <a href="/en/about">About</a>
        <a href="mailto:gujiayi2@gmail.com">Email</a>
      </div>
    </footer>
  </section>
</BaseLayout>

