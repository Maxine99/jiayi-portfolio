---
type Props = {
  variant?: "top" | "work";
};

const { variant = "top" } = Astro.props;
---

{variant === "top" ? (
  <>
    <div class="deco d1" aria-hidden="true">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
        <path
          d="M12 2l2.2 6.8H21l-5.5 4 2.1 6.6L12 15.8 6.4 19.4l2.1-6.6L3 8.8h6.8L12 2z"
          stroke="rgba(47,93,80,0.55)"
          stroke-width="1.2"
        />
      </svg>
    </div>
    <div class="deco d2" aria-hidden="true">
      <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
        <circle cx="9" cy="9" r="6.5" stroke="rgba(20,20,20,0.26)" stroke-width="1.2" />
        <circle cx="13" cy="5" r="1.2" fill="rgba(46,74,120,0.55)" />
      </svg>
    </div>
  </>
) : (
  <>
    <div class="deco d3" aria-hidden="true">
      <svg width="22" height="22" viewBox="0 0 22 22" fill="none">
        <path
          d="M11 2c2.2 2.9 3.2 4 7.5 5C14.2 8 13 9.2 11 13c-2.1-3.8-3.2-5-7.5-6 4.3-1 5.5-2.1 7.5-5z"
          stroke="rgba(47,93,80,0.40)"
          stroke-width="1.2"
          stroke-linejoin="round"
        />
      </svg>
    </div>
    <div class="deco d4" aria-hidden="true">
      <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
        <path
          d="M4 10h12M10 4v12"
          stroke="rgba(20,20,20,0.18)"
          stroke-width="1.2"
          stroke-linecap="round"
        />
      </svg>
    </div>
  </>
)}

<style>
  .d1 {
    top: 122px;
    left: clamp(12px, 6vw, 56px);
    animation: floaty 11s ease-in-out infinite;
  }
  .d2 {
    top: 170px;
    right: clamp(14px, 5vw, 54px);
    animation: floaty2 13s ease-in-out infinite;
  }
  .d3 {
    top: 18px;
    right: clamp(10px, 4vw, 22px);
    animation: floaty 12s ease-in-out infinite;
  }
  .d4 {
    bottom: -6px;
    left: clamp(10px, 4vw, 24px);
    animation: floaty2 14s ease-in-out infinite;
  }

  @keyframes floaty {
    0% {
      transform: translate3d(0, 0, 0) rotate(-1deg);
    }
    50% {
      transform: translate3d(0, -10px, 0) rotate(1.5deg);
    }
    100% {
      transform: translate3d(0, 0, 0) rotate(-1deg);
    }
  }

  @keyframes floaty2 {
    0% {
      transform: translate3d(0, 0, 0) rotate(1deg);
    }
    50% {
      transform: translate3d(0, 9px, 0) rotate(-1.2deg);
    }
    100% {
      transform: translate3d(0, 0, 0) rotate(1deg);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .d1,
    .d2,
    .d3,
    .d4 {
      animation: none !important;
    }
  }
</style>

